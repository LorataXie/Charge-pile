DATABASE_URL=sqlite+aiosqlite:///./charging_station.db
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 可复制为 .env 后修改；.env 会覆盖 config/settings.py 默认值。
# 修改 WAITING_AREA_SIZE / PILE_QUEUE_LENGTH / FAST_PILE_COUNT / SLOW_PILE_COUNT
#后重新运行 python cli/seed.py 并重启后端。

# 等候区总车位容量 WaitingAreaSize
WAITING_AREA_SIZE=10

# 每个充电桩排队队列长度 ChargingQueueLen
PILE_QUEUE_LENGTH=3

# 快充电桩数量 FastCharingPileNum
FAST_PILE_COUNT=3

# 慢充电桩数量 TrickleChargingPileNum
SLOW_PILE_COUNT=2

# 快充/慢充功率，默认 30 度/小时、10 度/小时
FAST_POWER_RATE=30.0
SLOW_POWER_RATE=10.0

# 仿真步长：每次 Tick 推进的虚拟分钟数
SIM_TICK_MINUTES=15
