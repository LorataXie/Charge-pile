DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/charging_station
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# System defaults (can be overridden in DB system_config)
WAITING_AREA_SIZE=10
PILE_QUEUE_LENGTH=3
FAST_PILE_COUNT=3
SLOW_PILE_COUNT=2
FAST_POWER_RATE=30.0
SLOW_POWER_RATE=10.0
SIM_TICK_MINUTES=15
